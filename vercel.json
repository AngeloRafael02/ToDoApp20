{
  "version": 2,
  "rewrites": [
    {
      "source": "/(api|utils|tasks|charts)/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "functions": {
    "api/index.js": {
      "includeFiles": "dist/your-project-name/**"
    }
  }
}
